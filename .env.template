# Groq API credentials for the vision analysis endpoint
GROQ_API_KEY=your_groq_api_key_here

# Optional override for the Groq API base URL
GROQ_API_URL=https://api.groq.com

# Optional local Hugging Face inference backend for OpenAI-compatible chat
HF_LOCAL_INFERENCE=false
HF_MODEL_NAME=humain-ai/ALLaM-7B-Instruct-preview
HF_DISABLE_CUDA=false

# Optional Meta LLaMA API support
LLAMA_USE_API=false
LLAMA_API_KEY=your_llama_api_key_here
LLAMA_API_URL=https://llama.developer.meta.com
